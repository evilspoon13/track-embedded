[Unit]
Description=Configure wlan0 for AP mode
Before=hostapd.service dnsmasq.service
After=network-pre.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/bash -c "ip addr flush dev wlan0; ip addr add 192.168.4.1/24 dev wlan0; ip link set wlan0 up"

[Install]
WantedBy=multi-user.target
