[Unit]
Description=TRACK CAN Reader
After=network.target track-setup.service track-can-interface.service
Requires=track-setup.service track-can-interface.service

[Service]
Type=simple
EnvironmentFile=-/opt/track/config/track.env
ExecStart=/opt/track/can-reader ${CAN_IFACE}
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
