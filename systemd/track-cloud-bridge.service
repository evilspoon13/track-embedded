[Unit]
Description=TRACK Cloud Bridge
After=network-online.target track-can-reader.service
Wants=network-online.target
Requires=track-can-reader.service

[Service]
Type=simple
ExecStart=/opt/track/cloud-bridge
Environment=CB_URL=ws://localhost:9002
Environment=CB_DEVICE_ID=dev-001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
